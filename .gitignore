# open-bridge — OSS .gitignore (PUBLIC repo).
#
# This file is a DESTINATION OVERRIDE: bridge-sync writes it verbatim to
# open-bridge on every promote (see skills/bridge-sync — § Destination
# overrides). It is NOT derived from the seed's private .gitignore, so the
# seed's "PII tracking is OK" inversion can never leak back into the public
# repo via a future sync.
#
# SAFE-BY-DEFAULT: the USER-layer PII categories below are IGNORED. A fork of
# a public repo is itself public by default — git would publish your tax data,
# contacts and config. So they stay local unless you deliberately opt in.
#
# OPT-IN (GitHub-as-offsite-backup, like the maintainer's private seed does):
# ONLY if your fork is PRIVATE, comment out the five PII blocks below. Then
# your USER-layer files get versioned + backed up. NEVER do this on a public
# fork — it publishes personal data irreversibly.

# --- USER-layer PII — IGNORED by default (see OPT-IN above) ----------------
# Root-anchored (leading /) so the shipped examples/agency/ copies stay tracked.
# bridge-config.yaml — your real config (upstreams, identity vars).
/bridge-config.yaml

# ecosystem.yaml — your real repo registry (created at onboarding, user-specific).
/ecosystem.yaml
# Personas — tax data, signature blocks, filing destinations.
identity/personas/*.yaml
!identity/personas/_template.yaml
!identity/personas/_schema.yaml
# Mandants — recipient contact PII.
identity/mandants/*.yaml
!identity/mandants/_template.yaml
!identity/mandants/_schema.yaml
# Accounts — mail/cal/cloud account references (URI refs, but still USER data).
identity/accounts/*.yaml
!identity/accounts/_template.yaml
!identity/accounts/_schema.yaml
# Contexts — routing configs (may name recipients/projects).
workflow/contexts/*.yaml
!workflow/contexts/_template.yaml
!workflow/contexts/_schema.yaml
# Calendars — scheduled outbound entries (who/what/when).
workflow/calendars/*.yaml
!workflow/calendars/_template.yaml
!workflow/calendars/_schema.yaml
# ---------------------------------------------------------------------------

# Doc-system audit log — concrete filenames + persona refs = PII.
work/doc-system/

# Onboarding scan findings — discovered apps/accounts/devices = PII.
# (work/onboarding-state.yaml stays tracked on purpose — record of choices.)
work/onboarding-scan.json

# Agent-activation session state — ephemeral per session, never committed.
.bridge-active-instance

# Work system data — large historical archives + private folders stay local.
work/imports/
# Top-level imports/ — content ignored, .gitkeep stays so the dir exists.
/imports/*
!/imports/.gitkeep
# work/archive/: days/ stays local (transcripts, audio, large artifacts).
# weeks/ is tracked — canonical historical record per week.
work/archive/days/

# Secrets-bearing build artifacts — publish-profiles, connection strings.
work/tasks/**/snapshots/
work/tasks/**/publish-profile*.xml
work/tasks/**/appsettings-*.json
work/streams/**/snapshots/
work/streams/**/publish-profile*.xml
work/streams/**/appsettings-*.json

# OS files
.DS_Store
Thumbs.db

# Editor files
*.swp
*.swo
*~

# IDE directories
.vscode/
.idea/

# Runtime artifacts
*.log
.env
.env.*
node_modules/
__pycache__/
*.pyc
.pytest_cache/
.prompt.tmp

# Image-gen scratch output at repo root
generated_imgs/

# Claude
.claude/scheduled_tasks.lock
.claude/settings.local.json
.claude/worktrees/

# Audio files anywhere under work/ (catch-all for accidental archives)
work/**/*.wav
work/**/*.m4a
work/**/*.mp3
work/**/*.aac
work/**/*.flac
work/**/*.ogg
work/**/*.aiff
work/**/*.aif

# Bridge no-log marker — present means "skip auto-logging this session"
.bridge-nolog

# Build artifacts regenerated by daemons (dashboard / schedule / state)
work/dashboard.html
docs/repo-layout/schedule.html
work/state.json
