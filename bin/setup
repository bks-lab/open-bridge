#!/usr/bin/env bash
# SPDX-License-Identifier: MIT
# Bridge — post-clone setup
#
# Ensures every supported AI agent can auto-discover the repo's skills by
# exposing the canonical top-level `skills/` folder at three discovery paths:
#   .claude/skills   (Claude Code)
#   .agents/skills   (Codex / Gemini CLI / Copilot CLI / Cursor)
#   .github/skills   (GitHub Copilot)
# All three ship as committed symlinks to `../skills`; this script repairs any
# that a checkout materialized as a plain file (e.g. native Windows git).
#
# macOS / Linux / WSL: works out of the box.
# Native Windows: see `bin/setup.ps1` instead (handles symlink quirks).

set -e

cd "$(dirname "$0")/.."

link_skills() {
    local target="$1"            # e.g. .claude/skills
    local parent="${target%/*}"  # e.g. .claude
    local source="../skills"

    if [ -L "$target" ] && [ -d "$target" ]; then
        echo "OK  $target is a working symlink"
        return 0
    fi
    if [ -d "$target" ] && [ ! -L "$target" ]; then
        echo "ERR $target exists as a real directory — manual review needed"
        echo "    (expected: symlink to $source)"
        return 1
    fi
    if [ -e "$target" ] || [ -L "$target" ]; then
        echo "INFO Removing broken $target (likely Windows-git symlink-as-textfile)"
        rm -f "$target"
    fi
    mkdir -p "$parent"
    ln -s "$source" "$target"
    echo "OK  Created $target -> $source"
}

rc=0
for t in .claude/skills .agents/skills .github/skills; do
    link_skills "$t" || rc=1
done

if [ -d ".claude/skills/bridge-onboard" ]; then
    echo "OK  Skill discovery verified (.claude/skills/bridge-onboard/ resolves)"
else
    echo "WARN Symlinks created but skills not visible — check that skills/ exists at repo root"
    rc=1
fi

# Arm the git hooks (rules/push-guard.md + the task-sync/logging backstop): route
# git hooks to the tracked dir. One setting wires BOTH scripts/hooks/pre-push (blocks
# publishing a user/* branch to a public upstream) AND scripts/hooks/pre-commit (the
# task-sync + continuous-logging reminder), for every tool that shells out to git.
# This `git config core.hooksPath` is THE single deterministic arming action — session
# start (Phase 0, rules/session-start.md) runs it unconditionally, and every non-Claude
# tool (Codex/Copilot/Gemini) is told to run `bin/setup` before its first commit.
# A hook that isn't on core.hooksPath is present but NOT wired.
# NOTE: do NOT `pre-commit install` — the pre-commit framework refuses when
# core.hooksPath is set; .pre-commit-config.yaml is for CI / manual runs only.
if [ -d "scripts/hooks" ]; then
    git config core.hooksPath scripts/hooks
    chmod +x scripts/hooks/* 2>/dev/null || true
    echo "OK  Git hooks armed (core.hooksPath -> scripts/hooks): pre-push guard + pre-commit task/log reminder"
else
    echo "WARN scripts/hooks/ missing — git hooks not armed"
fi

# Optional: the tool-agnostic gh wrapper (scripts/bin/gh) reminds you to log remote
# issue/PR/board ops. Not auto-written into your shell profile — opt in by adding it
# to PATH yourself:
if [ -x "scripts/bin/gh" ]; then
    echo "TIP gh log-reminder available — enable by adding to your shell profile:"
    echo "      export PATH=\"$(pwd)/scripts/bin:\$PATH\""
fi

exit "$rc"
