#!/bin/sh
# SPDX-License-Identifier: MIT
#
# pre-push guard — never publish USER data to a PUBLIC upstream.
#
# Why this exists: a Bridge cloned directly from a PUBLIC upstream (e.g.
# bks-lab/open-bridge) has `origin` pointing at that public repo. Onboarding
# commits identity + work/ to a user/* branch; the agent's auto-end-of-work
# cycle then pushes it — and a server-side ruleset can't stop the repo
# owner/org-admin's own push. This client-side hook is the deterministic
# backstop: it converts an accidental publish of your private branch into a
# deliberate, opt-in action — for the autopilot and the human alike.
#
# Detection is offline-first: the push target is classified into ONE of three
# states — private / public / unknown — from a built-in list + bridge-config.yaml
# push_guard.* + the `.bridge-origin` marker (is_public:true => public,
# is_public:false with a MATCHING repo: slug => private); only a still-unknown
# remote escalates to `gh repo view --json visibility`.
#
# SENSITIVE payload = a user/* destination OR pushed commits carrying USER content.
# It is ALLOWED to a CONFIRMED-PRIVATE target, BLOCKED to a CONFIRMED-PUBLIC one,
# and BLOCKED to an UNKNOWN/unverifiable one (fail-CLOSED — a re-homed origin that
# can't be proven private must not leak). A CORE-clean push (no user/* dest, no
# USER content) is ALLOWED to all three, so /promote forks + feature/* keep working.
#
# Deliberate bypass (visible, per-push):  BRIDGE_PUSH_GUARD=off git push ...
# Full rationale + remediation: rules/push-guard.md
set -u

REMOTE_NAME="${1:-}"
REMOTE_URL="${2:-}"

[ "${BRIDGE_PUSH_GUARD:-on}" = "off" ] && exit 0

ROOT=$(git rev-parse --show-toplevel 2>/dev/null) || ROOT=$(pwd)

# normalize any git remote URL to a lowercase owner/repo slug
slug_of() {
  printf '%s' "$1" \
    | sed -E 's#^git@[^:]+:##; s#^ssh://git@[^/]+/##; s#^https?://[^/]+/##; s#/$##; s#\.git$##' \
    | tr '[:upper:]' '[:lower:]'
}

# read a space-separated list under push_guard.<key> from a YAML file
# (supports inline `key: [a, b]` and block `- a` forms; best-effort, optional)
yaml_list() {
  _file="$1"; _key="$2"
  [ -f "$_file" ] || return 0
  awk -v key="$_key" '
    /^push_guard:/ { inpg=1; next }
    inpg && /^[^[:space:]#]/ { inpg=0 }
    inpg && $0 ~ "^[[:space:]]+" key ":" {
      l=$0; sub(/^[[:space:]]*[^:]+:[[:space:]]*/, "", l)
      if (l ~ /^\[/) { gsub(/[][,]/, " ", l); print l; ink=0; next }
      ink=1; next
    }
    ink && /^[[:space:]]*-[[:space:]]*/ { v=$0; sub(/^[[:space:]]*-[[:space:]]*/, "", v); printf "%s ", v; next }
    ink && /^[[:space:]]*[^[:space:]-]/ { ink=0 }
  ' "$_file" | tr -d "\"'" | tr '[:upper:]' '[:lower:]'
}

TARGET=$(slug_of "$REMOTE_URL")
CFG="$ROOT/bridge-config.yaml"

# ── Classify the push TARGET → private | public | unknown ───────────────────
# This drives how a SENSITIVE payload (user/* destination, or pushed commits that
# carry USER instance content) is handled in the ref loop below:
#   private  → ALLOW   (your own origin; deterministic & offline)
#   public   → BLOCK   (the 2026-06-24 user/* leak class)
#   unknown  → BLOCK   (fail-CLOSED: a re-homed / unverifiable remote can't be
#                       proven private, so sensitive data must not flow to it)
# A CORE-clean push is allowed to ALL THREE — see the [ -z "$blocked" ] gate below.
target_state=unknown

# 1) your own private remotes (config) — deterministic, offline → private
for p in $(yaml_list "$CFG" private_remotes); do
  [ "$TARGET" = "$p" ] && { target_state=private; break; }
done

# 2) built-in + config public upstreams → public
if [ "$target_state" = unknown ]; then
  for u in bks-lab/open-bridge $(yaml_list "$CFG" public_upstreams); do
    [ "$TARGET" = "$u" ] && { target_state=public; break; }
  done
fi

# 3) .bridge-origin marker — applied ONLY when its repo: slug matches THIS target,
#    so a stale marker from a previous origin can't vouch for a re-homed remote.
#    is_public:true => public; is_public:false => the deterministic, offline
#    "this is my private origin → allow" signal (previously a no-op).
if [ "$target_state" = unknown ] && [ -f "$ROOT/.bridge-origin" ]; then
  ob_repo=$(sed -n 's/^repo:[[:space:]]*//p' "$ROOT/.bridge-origin" | head -1 | tr -d "\"' " | tr '[:upper:]' '[:lower:]')
  ob_pub=$(sed -n 's/^is_public:[[:space:]]*//p' "$ROOT/.bridge-origin" | head -1 | tr -d " ")
  if [ -n "$ob_repo" ] && [ "$ob_repo" = "$TARGET" ]; then
    case "$ob_pub" in
      true)  target_state=public ;;
      false) target_state=private ;;
    esac
  fi
fi

# 4) still unknown → escalate to gh (best-effort). Offline / unknown repo / gh
#    absent ⇒ target_state stays `unknown` ⇒ sensitive payloads fail CLOSED.
#    Only an EXPLICIT PUBLIC/PRIVATE answer moves it off unknown (INTERNAL and any
#    other value stay unknown → blocked-for-sensitive, escapable via private_remotes).
if [ "$target_state" = unknown ] && command -v gh >/dev/null 2>&1; then
  vis=$(gh repo view "$TARGET" --json visibility -q .visibility 2>/dev/null)
  case "$vis" in
    PUBLIC)  target_state=public ;;
    PRIVATE) target_state=private ;;
  esac
fi

# A confirmed-private target is your own repo — nothing to guard, allow everything.
[ "$target_state" = private ] && exit 0

ZERO="0000000000000000000000000000000000000000"
# USER *instance* paths only — never CORE templates (_template/_schema, examples/,
# any _-prefixed basename, or a directory's own README.md). The destination-branch
# rule below is the primary guard; this content net is the backstop that catches
# USER instance files smuggled onto ANY other branch name (main, feature/*, a
# renamed user branch, …) — names are not trusted, content is.
USER_PATHS='^(work/(log\.md|board\.md|tasks/|streams/|done/|archive/)|identity/agent/(IDENTITY|SOUL)\.md|identity/(personas|mandants|accounts)/[^_]|infra/(remotes|channels|backups)/[^_]|workflow/calendars/[^_]|bridge-config\.yaml$)'

blocked=""
while read -r local_ref local_sha remote_ref remote_sha; do
  [ -z "${remote_ref:-}" ] && continue
  [ "$local_sha" = "$ZERO" ] && continue          # branch deletion — nothing pushed
  # Decide from where the ref LANDS (remote_ref), never the local ref: git feeds the
  # hook local_ref="HEAD" for `git push origin HEAD` and a raw sha for
  # `git push origin <sha>:refs/heads/user/x`, but remote_ref is ALWAYS the
  # fully-qualified destination. Keying on it means HEAD / detached / sha push forms
  # can't dodge the user/* rule (they did when this keyed on local_ref — leak vector).
  dest=${remote_ref#refs/heads/}
  case "$dest" in
    user/*) blocked="$blocked $dest"; continue ;;   # a USER branch never reaches a public upstream
  esac
  # Any other destination (main, feature/*, ci/*, promote-*, a renamed user branch):
  # allow it ONLY if the COMMITS being pushed carry no USER instance content. Inspect
  # the pushed commits, NOT the working tree — `git diff <sha>` against a clean tree
  # looks empty and hid the content (the other half of the leak vector).
  if [ "$remote_sha" = "$ZERO" ]; then
    push_commits=$(git rev-list "$local_sha" --not --remotes 2>/dev/null) || push_commits=""
  else
    push_commits=$(git rev-list "$remote_sha..$local_sha" 2>/dev/null) || push_commits=""
  fi
  changed=$(printf '%s\n' "$push_commits" | sed '/^$/d' \
            | git diff-tree -r --no-commit-id --name-only --root --stdin 2>/dev/null \
            | grep -v '/README\.md$') || changed=""
  if [ -n "$changed" ] && printf '%s\n' "$changed" | grep -Eq "$USER_PATHS"; then
    blocked="$blocked ${dest}(USER-content)"
  fi
done

# CORE-clean push (no user/* dest, no USER content) → allowed to ANY target.
[ -z "$blocked" ] && exit 0

if [ "$target_state" = public ]; then
  cat >&2 <<EOF

  ✋ Push blocked — public-upstream guard (rules/push-guard.md)

     remote   $REMOTE_NAME → $TARGET   ← PUBLIC upstream
     refs    $blocked

  USER-branch content (identity/agent, work/, client data) must never land on a
  public repo. The sanctioned path to a public upstream is a fork-based PR via
  /promote — never a direct push of your branch.

  Fix (recommended) — re-home this clone to a PRIVATE origin:
     git remote rename origin upstream
     gh repo create <you>/my-bridge --private --source=. --remote=origin --push
  open-bridge then stays a read-only pull/PR upstream you /promote into.

  Just evaluating? Keep user/* local — don't push at all.
  Intentional CORE-maintainer push? Override deliberately:
     BRIDGE_PUSH_GUARD=off git push ...

EOF
else
  cat >&2 <<EOF

  ✋ Push blocked — unverified remote, USER data withheld (rules/push-guard.md)

     remote   $REMOTE_NAME → $TARGET   ← NOT confirmed private (offline / unknown)
     refs    $blocked

  This push carries USER data (a user/* branch or USER instance content) to a
  remote I can't confirm is private — gh is offline/unavailable or the repo's
  visibility is unknown. To prevent an accidental public leak, USER data is held
  back until the remote is known to be yours.

  Fix — tell the guard this remote is private (pick one), then re-push:
     • bridge-config.yaml →  push_guard:
                               private_remotes: [$TARGET]
     • or .bridge-origin  →  repo: $TARGET
                             is_public: false

  CORE-only pushes (no user/* branch, no USER content) are NOT affected — they
  flow to any remote. Deliberate one-off override (visible, per-push):
     BRIDGE_PUSH_GUARD=off git push ...

EOF
fi
exit 1
